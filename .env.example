# 接入真实 POISS 后端(mac/MAC-POISS/poiss,默认 127.0.0.1:5124)时设为 true;否则前端用 mock。
# 切换后场景/组件代码零改动(见 src/api/backend.js)。
VITE_USE_REAL_API=false

# MindSpider 七平台统计(后端接入说明 §B6-1 的待新增接口)。后端实现后设 true 启用;
# 默认 false:不请求该端点(避免对不存在端点的 404),RightRail 七平台面板降级为空。
VITE_PLATFORM_STATS=false

# vite 开发代理目标(浏览器侧 /api/* 与 /health 经此转发到 POISS,规避 CORS)。
# 默认即 POISS 的 127.0.0.1:5124;仅当后端换了地址才需改。
VITE_POISS_TARGET=http://127.0.0.1:5124

# 真实适配层 fetch 的 base(默认空 = 相对路径,走 vite 代理)。一般无需设置。
# VITE_POISS_BASE=
